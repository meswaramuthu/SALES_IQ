{
  "prompt": {
    "source": "gcs",
    "gcs_uri": "gs://stratova-platform/agents/ops-iq/prompts/prompt.txt"
  },
  "tools": {
    "quota_monitoring": {
      "enabled": true,
      "config": {
        "services": ["aiplatform.googleapis.com"],
        "project": "env:GOOGLE_CLOUD_PROJECT"
      }
    },
    "metrics_monitoring": {
      "enabled": true,
      "config": {
        "default_lookback_hours": 24,
        "max_lookback_hours": 168
      }
    },
    "vertex_resources": {
      "enabled": true,
      "config": {
        "location": "env:GOOGLE_CLOUD_LOCATION"
      }
    },
    "user_usage_tracking": {
      "enabled": true,
      "config": {
        "firestore_collection": "ops_iq_usage",
        "retention_days": 90
      }
    },
    "gemini_enterprise": {
      "enabled": false,
      "config": {}
    },
    "alerting": {
      "enabled": true,
      "config": {
        "email_mcp_url": "env:EMAIL_MCP_URL",
        "from_email": "ops@stratova.ai",
        "from_name": "Ops IQ — Stratova AI",
        "to_emails": [
          "abdul@stratova.ai"
        ],
        "thresholds": {
          "error_rate_pct": 2.0,
          "latency_p99_ms": 30000,
          "token_daily_budget": 5000000,
          "request_daily_budget": 10000,
          "quota_utilisation_pct": 80
        }
      }
    }
  }
}
