{
  "_comment": "Copy this file to tools_config.json and set your values. Upload to GCS with scripts/upload_config.py.",
  "prompt": {
    "source": "gcs",
    "gcs_uri": "gs://YOUR_BUCKET/agents/ops-iq/prompts/prompt.txt"
  },
  "tools": {
    "quota_monitoring": {
      "enabled": true,
      "config": {
        "services": ["aiplatform.googleapis.com"],
        "project": "env:GOOGLE_CLOUD_PROJECT"
      }
    },
    "metrics_monitoring": {
      "enabled": true,
      "config": {
        "default_lookback_hours": 24,
        "max_lookback_hours": 168
      }
    },
    "vertex_resources": {
      "enabled": true,
      "config": {
        "location": "env:GOOGLE_CLOUD_LOCATION"
      }
    },
    "user_usage_tracking": {
      "enabled": true,
      "config": {
        "firestore_collection": "ops_iq_usage",
        "retention_days": 90
      }
    },
    "gemini_enterprise": {
      "enabled": false,
      "_comment": "Set to true if you have Gemini for Google Workspace and want to monitor its usage.",
      "config": {}
    }
  }
}
