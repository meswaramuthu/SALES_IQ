# Ops IQ — Environment Configuration
# Copy this file to .env and fill in your values before deploying.

# ── GCP Core ──────────────────────────────────────────────────────────────────
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_GENAI_USE_VERTEXAI=True

# ── GCS Config & Prompt ───────────────────────────────────────────────────────
STAGING_BUCKET=gs://your-project-id-staging
TOOLS_CONFIG_GCS_URI=gs://stratova-platform/agents/ops-iq/config/tools_config.json
PROMPT_GCS_URI=gs://stratova-platform/agents/ops-iq/prompts/prompt.txt

# ── Caching ───────────────────────────────────────────────────────────────────
CONFIG_CACHE_TTL_SECONDS=60

# ── Firestore Usage Tracking ──────────────────────────────────────────────────
FIRESTORE_USAGE_COLLECTION=ops_iq_usage

# ── Metrics Defaults ──────────────────────────────────────────────────────────
METRICS_DEFAULT_HOURS=24
METRICS_MAX_HOURS=168

# ── Alerting ──────────────────────────────────────────────────────────────────
EMAIL_MCP_URL=https://your-email-mcp-service.run.app/mcp
ALERT_TO_EMAILS=admin@yourcompany.com
ALERT_FROM_NAME=Ops IQ — Stratova AI

# ── Deployed Agent Resource Name ──────────────────────────────────────────────
# Populated automatically by deploy/deploy.py after first deploy
OPS_IQ_RESOURCE_NAME=
AGENT_ENGINE_ID=
