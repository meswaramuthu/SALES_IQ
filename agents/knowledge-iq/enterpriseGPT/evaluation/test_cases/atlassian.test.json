{
  "eval_set_id": "enterpriseGPT_atlassian_eval_set",
  "name": "Atlassian Tool Evaluation (Jira + Confluence)",
  "description": "Jira and Confluence are currently DISABLED in tools_config.json. These cases document expected behaviour once the connectors are enabled. Set jira.enabled=true and confluence.enabled=true in config/tools_config.json to activate.",
  "eval_cases": [
    {
      "eval_id": "jira_search_open_bugs",
      "conversation": [
        {
          "invocation_id": "c1b2c3d4-0001-4000-8000-000000000001",
          "user_content": {
            "parts": [{ "text": "Search Jira for all open bug tickets assigned to me." }],
            "role": "user"
          },
          "final_response": {
            "parts": [{ "text": "Here are the open Jira bug tickets assigned to you." }],
            "role": "model"
          },
          "intermediate_data": {
            "tool_uses": [
              {
                "name": "search_jira",
                "args": { "jql": "assignee = currentUser() AND issuetype = Bug AND status != Done ORDER BY created DESC" }
              }
            ],
            "intermediate_responses": []
          }
        }
      ],
      "session_input": {
        "app_name": "enterpriseGPT",
        "user_id": "eval_user",
        "state": {}
      }
    },
    {
      "eval_id": "jira_high_priority_issues",
      "conversation": [
        {
          "invocation_id": "c1b2c3d4-0002-4000-8000-000000000002",
          "user_content": {
            "parts": [{ "text": "What are all the high priority Jira issues in the current sprint?" }],
            "role": "user"
          },
          "final_response": {
            "parts": [{ "text": "Here are the high priority Jira issues in the current sprint." }],
            "role": "model"
          },
          "intermediate_data": {
            "tool_uses": [
              {
                "name": "search_jira",
                "args": { "jql": "sprint in openSprints() AND priority in (High, Highest) ORDER BY priority DESC" }
              }
            ],
            "intermediate_responses": []
          }
        }
      ],
      "session_input": {
