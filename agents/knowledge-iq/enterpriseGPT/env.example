# ── Google Cloud ──────────────────────────────────────────────────────────────
GOOGLE_GENAI_USE_VERTEXAI=1
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1

STAGING_BUCKET=gs://your-gcp-project-id-knowledge-iq
AGENT_ENGINE_ID=projects/YOUR_PROJECT_NUMBER/locations/us-central1/reasoningEngines/YOUR_ENGINE_ID
TOOLS_CONFIG_GCS_URI=gs://your-bucket/knowledge-iq/tools_config.json
PROMPT_GCS_URI=gs://your-bucket/knowledge-iq/prompt.txt
CONFIG_CACHE_TTL_SECONDS=60

# ── RAG ───────────────────────────────────────────────────────────────────────
RAG_CORPUS=projects/YOUR_PROJECT_NUMBER/locations/us-west1/ragCorpora/YOUR_CORPUS_ID
RAG_LOCATION=us-west1
RAG_EMBEDDING_MODEL=publishers/google/models/text-embedding-004
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=100
RAG_SIMILARITY_TOP_K=10
RAG_DISTANCE_THRESHOLD=0.6

# ── Gmail ─────────────────────────────────────────────────────────────────────
GMAIL_ENABLED=true
GMAIL_SA_KEY_GCS_URI=gs://your-bucket/creds/google-sa.json
GMAIL_USER_EMAIL=user@yourdomain.com
GMAIL_MAX_RESULTS=20

# ── Google Drive ──────────────────────────────────────────────────────────────
GDRIVE_ENABLED=true
GDRIVE_SA_KEY_GCS_URI=gs://your-bucket/creds/google-sa.json
GDRIVE_USER_EMAIL=user@yourdomain.com

# ── Google Calendar ───────────────────────────────────────────────────────────
CALENDAR_ENABLED=true
CALENDAR_SA_KEY_GCS_URI=gs://your-bucket/creds/google-sa.json
GOOGLE_CALENDAR_ID=user@yourdomain.com
CALENDAR_USER_EMAIL=user@yourdomain.com
CALENDAR_TIMEZONE=Asia/Singapore
MEET_TRANSCRIPT_ENABLED=true

# ── GitHub ────────────────────────────────────────────────────────────────────
GITHUB_ENABLED=true
GITHUB_TOKEN=ghp_YourPersonalAccessTokenHere
GITHUB_DEFAULT_ORG=your-github-org

# ── Jira ──────────────────────────────────────────────────────────────────────
JIRA_ENABLED=false
JIRA_URL=https://your-org.atlassian.net
JIRA_USERNAME=user@yourdomain.com
JIRA_API_TOKEN=your-jira-api-token

# ── Confluence ────────────────────────────────────────────────────────────────
CONFLUENCE_ENABLED=false
CONFLUENCE_URL=https://your-org.atlassian.net/wiki
CONFLUENCE_USERNAME=user@yourdomain.com
CONFLUENCE_API_TOKEN=your-confluence-api-token

# ── SharePoint ────────────────────────────────────────────────────────────────
SHAREPOINT_ENABLED=true
SHAREPOINT_TENANT_ID=your-azure-tenant-id
SHAREPOINT_CLIENT_ID=your-azure-app-client-id
SHAREPOINT_CLIENT_SECRET=your-azure-app-client-secret
SHAREPOINT_SITE_URL=https://yourorg.sharepoint.com/sites/YourSite
SHAREPOINT_SEARCH_REGION=APC
