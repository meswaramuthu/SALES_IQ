# ── Google Cloud ──────────────────────────────────────────────────────────────
GOOGLE_GENAI_USE_VERTEXAI=1
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1

STAGING_BUCKET=gs://your-gcp-project-id-sales-iq
AGENT_ENGINE_ID=projects/YOUR_PROJECT_NUMBER/locations/us-central1/reasoningEngines/YOUR_ENGINE_ID
TOOLS_CONFIG_GCS_URI=gs://your-bucket/sales-iq/tools_config.json
PROMPT_GCS_URI=gs://your-bucket/sales-iq/prompt.txt
CONFIG_CACHE_TTL_SECONDS=60

# ── CRM ───────────────────────────────────────────────────────────────────────
CRM_ENABLED=true
DEFAULT_CRM=hubspot

# HubSpot
HUBSPOT_API_KEY=your-hubspot-private-app-api-key

# Salesforce (optional — set DEFAULT_CRM=salesforce to use)
SALESFORCE_INSTANCE_URL=https://yourorg.my.salesforce.com
SALESFORCE_ACCESS_TOKEN=your-salesforce-access-token

# ── Google Calendar ───────────────────────────────────────────────────────────
CALENDAR_ENABLED=true
CALENDAR_SA_KEY_GCS_URI=gs://your-bucket/creds/google-sa.json
CALENDAR_USER_EMAIL=sales@yourdomain.com
GOOGLE_CALENDAR_ID=primary
CALENDAR_TIMEZONE=UTC

# ── Gmail ─────────────────────────────────────────────────────────────────────
GMAIL_ENABLED=true
GMAIL_SA_KEY_GCS_URI=gs://your-bucket/creds/google-sa.json
GMAIL_USER_EMAIL=sales@yourdomain.com
GMAIL_MAX_RESULTS=20

# ── Google Drive ──────────────────────────────────────────────────────────────
GDRIVE_ENABLED=true
GDRIVE_SA_KEY_GCS_URI=gs://your-bucket/creds/google-sa.json
GDRIVE_USER_EMAIL=sales@yourdomain.com
GDRIVE_PROPOSALS_FOLDER_ID=your-google-drive-proposals-folder-id
GDRIVE_TEMPLATES_FOLDER_ID=your-google-drive-templates-folder-id
GDRIVE_REPORTS_FOLDER_ID=your-google-drive-reports-folder-id
GDRIVE_CONTRACTS_FOLDER_ID=your-google-drive-contracts-folder-id
GDRIVE_PRICING_SHEET_ID=your-google-drive-pricing-sheet-id

# ── Apollo.io ─────────────────────────────────────────────────────────────────
APOLLO_ENABLED=true
APOLLO_API_KEY=your-apollo-io-api-key
APOLLO_MAX_RESULTS=25

# ── Clearbit ──────────────────────────────────────────────────────────────────
CLEARBIT_ENABLED=true
CLEARBIT_API_KEY=your-clearbit-api-key

# ── LinkedIn Sales Navigator ──────────────────────────────────────────────────
LINKEDIN_ENABLED=false
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret
LINKEDIN_ACCESS_TOKEN=your-linkedin-access-token

# ── DocuSign ──────────────────────────────────────────────────────────────────
DOCUSIGN_ENABLED=false
DOCUSIGN_ACCOUNT_ID=your-docusign-account-id
DOCUSIGN_INTEGRATION_KEY=your-docusign-integration-key
DOCUSIGN_USER_ID=your-docusign-user-id
DOCUSIGN_RSA_KEY_GCS_URI=gs://your-bucket/creds/docusign-rsa.pem
DOCUSIGN_PROPOSAL_TEMPLATE_ID=your-docusign-proposal-template-id
DOCUSIGN_CONTRACT_TEMPLATE_ID=your-docusign-contract-template-id
DOCUSIGN_NDA_TEMPLATE_ID=your-docusign-nda-template-id

# ── Slack ─────────────────────────────────────────────────────────────────────
SLACK_ENABLED=true
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_DEFAULT_CHANNEL=#sales

# ── Notion (optional) ─────────────────────────────────────────────────────────
NOTION_ENABLED=false
NOTION_API_TOKEN=your-notion-integration-token
